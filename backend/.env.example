# Database — for local dev, DB runs via Docker Compose on localhost
# When running inside Docker Compose, DB_HOST is overridden to "db" automatically
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=chatuser
DB_PASSWORD=chatpass
DB_NAME=chat-support

# Public URL of the frontend — used for CORS and OAuth redirects
# For local dev (preview): http://localhost:4173
# For Docker Compose / production: http://localhost or your deployed domain
WIDGET_URL=http://localhost:4173

# SMTP configuration (used for sending verification codes)
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM=noreply@your-domain.com

# Slack — fill in after completing the Slack setup steps
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_REDIRECT_URI=https://your-domain.com/slack/oauth_redirect
SLACK_BOT_TOKEN=xoxb-your-bot-token

# JWT signing key — use any random string for local development
JWT_SECRET=change-me-in-production
